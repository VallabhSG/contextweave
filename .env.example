# ContextWeave Environment Configuration
# Copy this file to .env and fill in your values

# Required: Google Gemini API key
# Get one at: https://aistudio.google.com/app/apikey
CW_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override defaults
# CW_CHROMA_PERSIST_DIR=./chroma_data
# CW_SQLITE_DB_PATH=./contextweave.db
# CW_REASONING_MODEL=models/gemini-2.0-flash
# CW_EMBEDDING_MODEL=models/text-embedding-004
# CW_HOST=0.0.0.0
# CW_PORT=8000
# CW_DECAY_HALF_LIFE_DAYS=30.0
# CW_RETRIEVAL_FINAL_K=8
